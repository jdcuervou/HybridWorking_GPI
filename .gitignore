# Datos sin procesar
data/raw/*
!data/raw/.gitkeep
!data/raw/README_raw_data.md

# Datos procesados (solo archivos grandes)
data/processed/*
!data/processed/.gitkeep
!data/processed/README.md


############################
# Results
############################

# Resultados reproducibles (mantener estructura)
results/figures/*
results/tables/*
!results/**/.gitkeep
!results/README.md

# Carpeta exploratory removida del proyecto
results/exploratory/


